POSTGRES_USER=nba
POSTGRES_PASSWORD=nba
POSTGRES_DB=nba
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# e.g. sslmode=require&channel_binding=require for a hosted provider (Neon,
# Supabase) that mandates TLS -- leave blank for local docker-compose.
POSTGRES_QUERY=

# Phase 4 agent service
ANTHROPIC_API_KEY=
AGENT_DB_USER=agent_readonly
AGENT_DB_PASSWORD=changeme-dev-only
AGENT_ROW_LIMIT=200
AGENT_STATEMENT_TIMEOUT_MS=5000

# Phase 2 dashboard
AGENT_SERVICE_URL=http://localhost:8000
# Leave blank for local dev (no gate). Set before deploying publicly.
DASHBOARD_PASSWORD=
# Set to false for the public deployment (its hosted DB omits play_by_play
# to fit a free tier) -- both the agent and the dashboard read this to
# explain the gap instead of silently failing on a missing table.
PLAY_BY_PLAY_AVAILABLE=true
